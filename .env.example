# Copy this file to .env.local for local development.

# Debug-only preset tools. Set to true to show temporary preset copy controls.
NEXT_PUBLIC_ENABLE_DEBUG_PRESETS=false

# Debug-only template tools. Set to true to show the "Copy template" button
# that captures the current composition as template JSON.
NEXT_PUBLIC_ENABLE_TEMPLATE_COPY=false

# Comma-separated emails allowed to publish template posters via
# POST /api/templates/thumb (still blocked in production). Empty = nobody.
TEMPLATE_MAINTAINER_EMAILS=

# Sentry. Optional, used for client and server error/log capture.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=side-
SENTRY_PROJECT=

# Cloudflare R2. Required for share, draft, and media storage.
R2_ACCOUNT_ID=
R2_BUCKET=
R2_S3_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_API_TOKEN=

# Unsplash API. Optional, used by Unsplash API routes.
UNSPLASH_ACCESS_KEY=

# Better Auth. Required for auth flows.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Cloudflare D1 is configured as the TOKOKINO_DB binding in wrangler.jsonc.

# Google OAuth. Optional.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare Browser Rendering. Required for automatic screenshot capture.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_BROWSER_API_TOKEN=

# Discord webhook that receives in-app feedback submissions. Optional — when
# unset, feedback is accepted but silently dropped (dev/self-host friendly).
FEEDBACK_DISCORD_WEBHOOK_URL=
