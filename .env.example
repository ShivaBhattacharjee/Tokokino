# R2 public base URL (all asset URLs are derived from this)
NEXT_PUBLIC_R2_PUBLIC_BASE=https://your-r2-public-url.r2.dev

# Cloudflare R2 (server-side only, used by build scripts)
R2_ACCOUNT_ID=
R2_BUCKET=
R2_S3_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_API_TOKEN=

# Unsplash API (server-side, used by API routes)
UNSPLASH_ACCESS_KEY=

# Better Auth (server-side)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# MongoDB (server-side, see docker-compose.yml for local default)
MONGODB_URI=mongodb://noctivy:noctivy@localhost:27017/noctivy?authSource=admin&replicaSet=rs0&retryWrites=true

# Google OAuth (server-side)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
